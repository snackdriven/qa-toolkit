# Required for all Jira scripts
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token

# Required for gemini-video-analyze.ts
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Optional: override Jira base URL (default: parsed from release URL)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Optional: Google Calendar integration (jira-release-notes.ts)
GOOGLE_CALENDAR_TOKEN=your_oauth_token
WORK_CALENDAR_ID=primary
TIMEZONE=America/Chicago

# Optional: path to a markdown checklist file embedded in day-before calendar events
CHECKLIST_PATH=./qa-release-checklist.md
